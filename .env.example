# Device credentials (a single set for the lab; extend per-group as needed)
NETOPS_USERNAME=netadmin
NETOPS_PASSWORD=change-me
NETOPS_SECRET=change-me

# Inventory and storage
NETOPS_INVENTORY_PATH=inventory/devices.yaml
NETOPS_CONFIG_STORE=data/configs

# Config backup git remote (a DEDICATED repo for configs, not this toolkit repo)
NETOPS_GIT_REMOTE=
NETOPS_GIT_BRANCH=main
NETOPS_GIT_AUTHOR_NAME=netops-automation
NETOPS_GIT_AUTHOR_EMAIL=netops-automation@localhost

# NetBox
NETOPS_NETBOX_URL=
NETOPS_NETBOX_TOKEN=

# Runtime
NETOPS_MAX_WORKERS=8
NETOPS_LOG_LEVEL=INFO
